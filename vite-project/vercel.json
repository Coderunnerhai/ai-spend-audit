{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    {
      "src": "/assets/index.js",
      "headers": {
        "Content-Type": "application/javascript"
      },
      "dest": "/assets/index.js"
    },
    {
      "src": "/assets/index.css",
      "headers": {
        "Content-Type": "text/css"
      },
      "dest": "/assets/index.css"
    },
    {
      "src": "/audit/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}